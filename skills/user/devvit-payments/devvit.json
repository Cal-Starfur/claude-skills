{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "test-payments-dw",
  "payments": {
    "products": [
      {
        "sku": "premium-badge",
        "displayName": "Premium Badge",
        "description": "A shiny premium badge to show off your support!",
        "price": 25,
        "accountingType": "INSTANT"
      }
    ],
    "endpoints": {
      "fulfillOrder": "/internal/payments/fulfill",
      "refundOrder": "/internal/payments/refund"
    }
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "media": {
    "dir": "assets"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "test-payments-dw",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "dev": {
    "subreddit": "test_payments_dw_dev"
  }
}